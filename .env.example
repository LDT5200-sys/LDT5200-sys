# ===== 大模型接口 =====
# 每人用自己的 DeepSeek API Key → https://platform.deepseek.com
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
AI_TEMPERATURE=0.2
KEYWORD_MODEL=
AI_MAX_TOKENS=1200
AI_MAX_RETRIES=2
ENABLE_AI=true

# ===== 搜索 API =====
SEARCH_API_PROVIDER=bocha
SEARCH_API_KEY=sk-xxxx
SEARCH_API_BASE_URL=
SEARCH_API_RESULT_LIMIT=20
SEARCH_DOMAIN_FILTER=douyin.com

# ===== CDP Chrome 模式（无需配置，启动带调试端口的 Chrome 即可） =====
DOUYIN_DATA_PROVIDER=
DOUYIN_API_KEY=
DOUYIN_API_BASE_URL=

# ===== 飞书多维表（所有人共享同一份配置，找管理员要） =====
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx
FEISHU_BITABLE_APP_TOKEN=xxxx
FEISHU_BITABLE_TABLE_ID=xxxx
