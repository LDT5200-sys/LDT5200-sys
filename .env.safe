# ===== 大模型（OpenAI 兼容协议） =====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1200
AI_MAX_RETRIES=2
ENABLE_AI=true

# 关键词扩展专用模型，可与主模型不同；留空则复用 OPENAI_MODEL
KEYWORD_MODEL=

# ===== 搜索 API（公开候选发现） =====
# SEARCH_API_PROVIDER 可选：serper / serpapi / bing / bocha / generic
# - bocha: 博查 Web Search API，国内可用，微信扫码注册 https://open.bochaai.com
#   端点：https://api.bochaai.com/v1/web-search，POST + Bearer token
SEARCH_API_PROVIDER=
SEARCH_API_KEY=
SEARCH_API_BASE_URL=
SEARCH_API_RESULT_LIMIT=20
SEARCH_DOMAIN_FILTER=douyin.com,xingtu.cn,xiaohongshu.com

# ===== 抖音/授权数据源（补全公开视频与账号信息） =====
# DOUYIN_DATA_PROVIDER 留空则跳过该数据源
# 自建/三方代理一律走 generic 模式：把 endpoint 与字段映射放到 config/data_sources.yaml
DOUYIN_DATA_PROVIDER=
DOUYIN_API_KEY=
DOUYIN_API_SECRET=
DOUYIN_ACCESS_TOKEN=
DOUYIN_API_BASE_URL=

# ===== 星图/商务达人数据源 =====
XINGTU_DATA_PROVIDER=
XINGTU_API_KEY=
XINGTU_API_SECRET=
XINGTU_ACCESS_TOKEN=
XINGTU_API_BASE_URL=
# 不接 API 也可以使用导出表模式：把星图导出文件放到 data/input/xingtu/

# ===== 第三方达人数据工具（如新榜、蝉妈妈、果集等） =====
THIRD_PARTY_PROVIDER=
THIRD_PARTY_API_KEY=
THIRD_PARTY_API_BASE_URL=
# 不接 API 也可以使用导出表模式：把工具导出文件放到 data/input/third_party/

# ===== 飞书多维表（占位，第一版不真实写入） =====
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# ===== 兼容旧字段（与 SEARCH_API_PROVIDER / KEY 等价，仍可继续使用） =====
SEARCH_PROVIDER=
SEARCH_RESULT_LIMIT=
